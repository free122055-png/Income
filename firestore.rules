rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Hardened Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
      );
    }

    function isOrgAdmin(orgId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'orgadmin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "free122055@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')
      );
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid;
    }

    function isValidVerification(data) {
      return data.userId == request.auth.uid && (data.status == "pending" || data.status == "approved");
    }

    function isValidId(id) {
      return id.size() > 0;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || (isSignedIn() && isOrgAdmin(get(/databases/$(database)/documents/users/$(userId)).data.orgId));
      allow list: if isSuperAdmin() || (isSignedIn() && isOrgAdmin(request.query.limit > 0 && request.query.orgId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId));
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isSuperAdmin();
    }

    match /organizations/{orgId} {
      allow read: if true; // Public for verification pages
      allow write: if isSuperAdmin();
      allow update: if isSuperAdmin() || isOrgAdmin(orgId);
    }

    match /verifications/{verificationId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin() || isOrgAdmin(resource.data.orgId));
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin() || (isOrgAdmin(request.query.orgId)));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (isSignedIn() && isOrgAdmin(resource.data.orgId));
    }

    // 5. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.email == "free122055@gmail.com";
    }
  }
}
